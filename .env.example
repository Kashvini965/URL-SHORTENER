PORT=5000
MONGO_URI=mongodb://localhost:27017/url_shortener
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
BASE_URL=http://localhost:5000
# PUBLIC_URL — URL phones use for QR codes & short links (required for cross-network scanning)
# Same Wi‑Fi: auto-uses your laptop IP. Different networks: use ngrok or your deployed domain.
# PUBLIC_URL=https://your-subdomain.ngrok-free.app
CLIENT_URL=http://localhost:3000

# SMTP email settings for forgot-password
# These are backend mail server credentials used by your app to send reset emails.
# Do NOT ask users for their Gmail passwords in the app.
# Example Gmail SMTP settings use an app password from your own account.
MAIL_SERVICE=Gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-email-app-password
MAIL_FROM="URL Shortener <your-email@gmail.com>"
